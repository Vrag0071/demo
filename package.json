{
  "name": "catalog-flow-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram bot MVP for product catalog submissions and moderation.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "site": "ts-node-dev --respawn --transpile-only src/site.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "prisma:migrate": "prisma migrate dev --name init",
    "db:init": "node scripts/init-sqlite.mjs",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "dotenv": "^16.4.7",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prisma": "^6.19.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
